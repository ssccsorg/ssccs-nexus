{
  "name": "edgequake/sdk",
  "description": "PHP SDK for the EdgeQuake RAG API",
  "type": "library",
  "license": "Apache-2.0",
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "EdgeQuake\\": "src/"
    },
    "classmap": ["src/Services.php"]
  },
  "autoload-dev": {
    "psr-4": {
      "EdgeQuake\\Tests\\": "tests/"
    }
  }
}
