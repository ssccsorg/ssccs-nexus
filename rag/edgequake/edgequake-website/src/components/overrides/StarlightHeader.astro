---
import LanguageSelect from "@astrojs/starlight/components/LanguageSelect.astro";
import Search from "@astrojs/starlight/components/Search.astro";
import SiteTitle from "@astrojs/starlight/components/SiteTitle.astro";
import SocialIcons from "@astrojs/starlight/components/SocialIcons.astro";
import ThemeSelect from "@astrojs/starlight/components/ThemeSelect.astro";
import config from "virtual:starlight/user-config";

const pathname = Astro.url.pathname;
const navLinks = [
  { label: "Docs", href: "/docs/" },
  { label: "Demo", href: "/demo/" },
  { label: "Ecosystem", href: "/ecosystem/" },
  { label: "Enterprise", href: "/enterprise/" },
];

const shouldRenderSearch =
  config.pagefind ||
  config.components.Search !== "@astrojs/starlight/components/Search.astro";

const isActivePath = (href: string) => {
  if (href === "/docs/") {
    return pathname.startsWith("/docs/");
  }

  return pathname.startsWith(href);
};
---

<div class="header">
  <div class="title-wrapper sl-flex">
    <SiteTitle />
  </div>

  {
    shouldRenderSearch && (
      <div class="search-wrapper sl-flex print:hidden">
        <Search />
      </div>
    )
  }

  <nav
    class="eq-docs-nav sl-hidden lg:sl-flex print:hidden"
    aria-label="Site navigation"
  >
    {
      navLinks.map((link) => (
        <a
          href={link.href}
          class="eq-docs-link"
          aria-current={isActivePath(link.href) ? "page" : undefined}
        >
          {link.label}
        </a>
      ))
    }
  </nav>

  <div class="sl-hidden md:sl-flex print:hidden right-group">
    <div class="sl-flex social-icons">
      <SocialIcons />
    </div>
    <ThemeSelect />
    <LanguageSelect />
  </div>
</div>

<style>
  @layer starlight.core {
    .header {
      display: flex;
      gap: var(--sl-nav-gap);
      justify-content: space-between;
      align-items: center;
      min-height: 100%;
      width: 100%;
    }

    .title-wrapper {
      overflow: clip;
      padding: 0.25rem;
      margin: -0.25rem;
      min-width: 0;
    }

    .search-wrapper {
      min-width: 0;
    }

    .search-wrapper :global(.search) {
      width: min(100%, 23rem);
    }

    .eq-docs-nav,
    .right-group,
    .social-icons {
      gap: 0.875rem;
      align-items: center;
    }

    .eq-docs-nav {
      justify-content: flex-end;
      min-width: max-content;
    }

    .eq-docs-link {
      color: var(--sl-color-gray-3);
      text-decoration: none;
      font-size: var(--sl-text-xs);
      line-height: 1;
      padding: 0.45rem 0.7rem;
      border-radius: 999px;
      transition:
        color 0.15s ease,
        background-color 0.15s ease;
    }

    .eq-docs-link:hover,
    .eq-docs-link[aria-current="page"] {
      color: var(--sl-color-white);
      background: color-mix(in srgb, var(--sl-color-accent) 14%, transparent);
    }

    .social-icons::after {
      content: "";
      height: 2rem;
      border-inline-end: 1px solid var(--sl-color-gray-5);
    }

    @media (min-width: 50rem) {
      :global(:root[data-has-sidebar]) {
        --__sidebar-pad: calc(2 * var(--sl-nav-pad-x));
      }

      :global(:root:not([data-has-toc])) {
        --__toc-width: 0rem;
      }

      .header {
        --__sidebar-width: max(
          0rem,
          var(--sl-content-inline-start, 0rem) - var(--sl-sidebar-width)
        );
        --__main-column-fr: calc(
          (
              100% + var(--__sidebar-pad, 0rem) -
                var(--__toc-width, var(--sl-sidebar-width)) -
                (2 * var(--__toc-width, var(--sl-nav-pad-x))) -
                var(--sl-content-inline-start, 0rem) - var(--sl-content-width)
            ) /
            2
        );

        display: grid;
        grid-template-columns:
          minmax(
            calc(
              var(--__sidebar-width) +
                max(0rem, var(--__main-column-fr) - var(--sl-nav-gap))
            ),
            auto
          )
          minmax(18rem, 1fr)
          auto
          auto;
        align-content: center;
      }

      .search-wrapper {
        justify-self: center;
        width: min(100%, 25rem);
      }
    }

    @media (max-width: 80rem) {
      .eq-docs-nav {
        display: none;
      }

      .header {
        grid-template-columns:
          minmax(
            calc(
              var(--__sidebar-width, 0rem) +
                max(0rem, var(--__main-column-fr, 0rem) - var(--sl-nav-gap))
            ),
            auto
          )
          minmax(16rem, 1fr)
          auto;
      }
    }
  }
</style>
