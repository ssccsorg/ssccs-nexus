---

<section class="py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto">
      <h2 class="text-3xl font-bold tracking-tight mkt-text sm:text-4xl">
        Built for Real Graph-RAG Work
      </h2>
      <p class="mt-4 text-lg mkt-text-muted">
        EdgeQuake combines ingestion, extraction, storage, and retrieval into a
        stack that is easier to reason about, easier to operate, and easier to
        extend.
      </p>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        features.map((f) => (
          <a
            href={f.href}
            class="mkt-card group rounded-xl p-6 transition-all hover:border-accent-500/30"
          >
            <div class="mkt-accent-surface mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg">
              <svg
                class="h-5 w-5"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d={iconPaths[f.icon]} />
              </svg>
            </div>
            <h3 class="text-lg font-semibold mkt-text group-hover:mkt-accent-text transition-colors">
              {f.title}
            </h3>
            <p class="mt-2 text-sm mkt-text-muted leading-relaxed">
              {f.description}
            </p>
          </a>
        ))
      }
    </div>
  </div>
</section>
