---
import EnterpriseCTA from "../components/sections/EnterpriseCTA.astro";
import MarketingLayout from "../layouts/MarketingLayout.astro";
---

<MarketingLayout
  title="Enterprise Graph-RAG | EdgeQuake"
  description="EdgeQuake for enterprise: self-hosted Graph-RAG with workspace isolation, Apache 2.0 license, on-premise deployment, and no cloud embedding dependency."
>
  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="text-4xl font-bold tracking-tight mkt-text sm:text-5xl">
          EdgeQuake for Enterprise
        </h1>
        <p class="mt-6 text-lg mkt-text-muted">
          Production-grade Graph-RAG for teams that need deployment control,
          workspace isolation, reliable operations, and a path from prototype to
          internal platform.
        </p>
        <p class="mt-4 text-sm leading-relaxed mkt-text-dim">
          Use this page to understand how EdgeQuake fits air-gapped
          environments, private model hosting, customer-facing systems, and
          multi-team knowledge platforms.
        </p>
      </div>
    </div>
  </section>

  <!-- Feature pillars -->
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 md:grid-cols-3">
        <div class="mkt-card rounded-xl p-8">
          <h2 class="text-xl font-semibold mkt-text">Self-Hosted</h2>
          <p class="mt-3 mkt-text-muted">
            Deploy on your own infrastructure. Air-gapped environments, private
            clouds, or on-premises — EdgeQuake runs wherever you need it.
          </p>
          <ul class="mt-4 space-y-2 text-sm mkt-text-muted">
            <li class="flex items-center gap-2">
              <span class="mkt-success-text">✓</span> Docker & Kubernetes ready
            </li>
            <li class="flex items-center gap-2">
              <span class="mkt-success-text">✓</span> Private LLM support (Ollama/vLLM)
            </li>
            <li class="flex items-center gap-2">
              <span class="mkt-success-text">✓</span> No data leaves your network
            </li>
          </ul>
        </div>

        <div class="mkt-card rounded-xl p-8">
          <h2 class="text-xl font-semibold mkt-text">Multi-Tenant</h2>
          <p class="mt-3 mkt-text-muted">
            Workspace isolation built into the core. Run multiple teams,
            clients, or projects on a single deployment with zero knowledge
            bleed.
          </p>
          <ul class="mt-4 space-y-2 text-sm mkt-text-muted">
            <li class="flex items-center gap-2">
              <span class="mkt-success-text">✓</span> Per-workspace encryption
            </li>
            <li class="flex items-center gap-2">
              <span class="mkt-success-text">✓</span> RBAC-ready architecture
            </li>
            <li class="flex items-center gap-2">
              <span class="mkt-success-text">✓</span> Audit logging
            </li>
          </ul>
        </div>

        <div class="mkt-card rounded-xl p-8">
          <h2 class="text-xl font-semibold mkt-text">Scalable</h2>
          <p class="mt-3 mkt-text-muted">
            Process millions of documents with constant memory usage. Horizontal
            scaling via PostgreSQL and stateless API servers.
          </p>
          <ul class="mt-4 space-y-2 text-sm mkt-text-muted">
            <li class="flex items-center gap-2">
              <span class="mkt-success-text">✓</span> 300MB memory per core
            </li>
            <li class="flex items-center gap-2">
              <span class="mkt-success-text">✓</span> Horizontal API scaling
            </li>
            <li class="flex items-center gap-2">
              <span class="mkt-success-text">✓</span> Connection pooling built-in
            </li>
          </ul>
        </div>
      </div>

      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        <a
          href="/docs/operations/deployment/"
          class="mkt-card rounded-xl p-6 transition-colors hover:border-accent-500/30"
        >
          <h2 class="text-lg font-semibold mkt-text">Deployment guide</h2>
          <p class="mt-2 text-sm mkt-text-muted">
            Review environment setup, service architecture, and deployment
            mechanics.
          </p>
        </a>
        <a
          href="/docs/operations/configuration/"
          class="mkt-card rounded-xl p-6 transition-colors hover:border-accent-500/30"
        >
          <h2 class="text-lg font-semibold mkt-text">
            Configuration reference
          </h2>
          <p class="mt-2 text-sm mkt-text-muted">
            Understand provider, database, and runtime configuration options.
          </p>
        </a>
        <a
          href="/contact/"
          class="mkt-card rounded-xl p-6 transition-colors hover:border-accent-500/30"
        >
          <h2 class="text-lg font-semibold mkt-text">Implementation support</h2>
          <p class="mt-2 text-sm mkt-text-muted">
            Talk to the team about architecture reviews, rollout planning, or
            custom integration work.
          </p>
        </a>
      </div>
    </div>
  </section>

  <EnterpriseCTA />
</MarketingLayout>
