---
import MarketingLayout from "../layouts/MarketingLayout.astro";
---

<MarketingLayout
  title="Page Not Found"
  description="The page you requested could not be found. Return to the EdgeQuake homepage or continue into the documentation."
  noIndex={true}
>
  <section class="flex min-h-[70vh] items-center justify-center py-24">
    <div class="text-center">
      <div
        class="mkt-accent-surface mx-auto mb-6 inline-flex h-20 w-20 items-center justify-center rounded-2xl"
      >
        <svg
          class="h-10 w-10"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
        </svg>
      </div>

      <h1 class="text-7xl font-extrabold mkt-text">404</h1>
      <p class="mt-4 text-xl mkt-text-secondary">Page Not Found</p>
      <p class="mt-2 mkt-text-dim">
        The page you're looking for doesn't exist or has moved.
      </p>

      <p class="mt-4 max-w-xl text-sm leading-relaxed mkt-text-muted mx-auto">
        Continue with the <a
          href="/docs/"
          class="mkt-accent-text hover:underline">documentation</a
        >, explore the <a href="/demo/" class="mkt-accent-text hover:underline"
          >demo workflow</a
        >, browse the <a
          href="/ecosystem/"
          class="mkt-accent-text hover:underline">crate ecosystem</a
        >, or review <a
          href="/enterprise/"
          class="mkt-accent-text hover:underline">enterprise deployment paths</a
        >.
      </p>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/"
          class="inline-flex items-center rounded-lg bg-accent-600 px-6 py-3 text-sm font-semibold text-white hover:bg-accent-500 transition-colors"
        >
          Back to Home
        </a>
        <a
          href="/docs/"
          class="mkt-outline-button px-6 py-3 text-sm font-semibold"
        >
          Documentation
        </a>
        <a
          href="/demo/"
          class="mkt-outline-button px-6 py-3 text-sm font-semibold"
        >
          Demo Workflow
        </a>
      </div>
    </div>
  </section>
</MarketingLayout>
