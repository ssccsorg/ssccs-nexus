---
import EcosystemSection from "../components/sections/Ecosystem.astro";
import MarketingLayout from "../layouts/MarketingLayout.astro";
---

<MarketingLayout
  title="Rust Crate Ecosystem | EdgeQuake"
  description="Explore EdgeQuake's modular Rust crates: ingestion pipeline, knowledge graph engine, PDF vision processor, REST API, query engine, and LLM provider adapters."
>
  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="text-4xl font-bold tracking-tight mkt-text sm:text-5xl">
          The EdgeQuake Ecosystem
        </h1>
        <p class="mt-6 text-lg mkt-text-muted">
          A modular Rust workspace for teams building Graph-RAG systems,
          document pipelines, query services, and graph-aware developer tools.
        </p>
        <p class="mt-4 text-sm leading-relaxed mkt-text-dim">
          Start here if you need to understand which crate owns ingestion,
          storage, retrieval, PDF conversion, or service delivery before you
          adopt the full platform or embed just part of it.
        </p>
      </div>
    </div>
  </section>

  <EcosystemSection />

  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-10 grid gap-6 lg:grid-cols-3">
        <div class="mkt-card rounded-xl p-8">
          <h2 class="text-xl font-semibold mkt-text">If you are evaluating</h2>
          <p class="mt-3 text-sm leading-relaxed mkt-text-muted">
            Start with the <a
              href="/demo/"
              class="mkt-accent-text hover:underline">demo workflow</a
            >
            and the <a
              href="/docs/getting-started/"
              class="mkt-accent-text hover:underline">getting started docs</a
            >
            to see how the pieces fit together in a real stack.
          </p>
        </div>

        <div class="mkt-card rounded-xl p-8">
          <h2 class="text-xl font-semibold mkt-text">If you are integrating</h2>
          <p class="mt-3 text-sm leading-relaxed mkt-text-muted">
            Use the <a
              href="/docs/api-reference/"
              class="mkt-accent-text hover:underline">API reference</a
            >
            and <a
              href="/docs/integrations/"
              class="mkt-accent-text hover:underline">integration guides</a
            >
            to choose the right boundary for your application.
          </p>
        </div>

        <div class="mkt-card rounded-xl p-8">
          <h2 class="text-xl font-semibold mkt-text">If you are deploying</h2>
          <p class="mt-3 text-sm leading-relaxed mkt-text-muted">
            Continue to the <a
              href="/enterprise/"
              class="mkt-accent-text hover:underline">enterprise page</a
            >
            and the <a
              href="/docs/operations/"
              class="mkt-accent-text hover:underline">operations docs</a
            >
            for self-hosting, scaling, and production guidance.
          </p>
        </div>
      </div>

      <div class="grid gap-8 md:grid-cols-2">
        <div class="mkt-card rounded-xl p-8">
          <h2 class="text-xl font-semibold mkt-text">Install from crates.io</h2>
          <div class="mkt-code-surface mt-4 rounded-lg p-4">
            <code class="text-sm mkt-accent-text">cargo add edgequake</code>
          </div>
          <p class="mt-4 text-sm mkt-text-muted">
            Add EdgeQuake to your Rust project. The main crate re-exports all
            sub-crates for convenience.
          </p>
        </div>

        <div class="mkt-card rounded-xl p-8">
          <h2 class="text-xl font-semibold mkt-text">Docker Quick Start</h2>
          <div class="mkt-code-surface mt-4 rounded-lg p-4">
            <code class="text-sm mkt-accent-text">docker compose up -d</code>
          </div>
          <p class="mt-4 text-sm mkt-text-muted">
            Launch EdgeQuake with PostgreSQL, Ollama, and the web UI in one
            command. No Rust toolchain needed.
          </p>
        </div>
      </div>

      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="/docs/getting-started/quick-start/"
          class="mkt-outline-button px-5 py-3 text-sm font-semibold"
        >
          Quick start guide
        </a>
        <a
          href="/docs/architecture/"
          class="mkt-outline-button px-5 py-3 text-sm font-semibold"
        >
          Architecture docs
        </a>
        <a
          href="/contact/"
          class="mkt-outline-button px-5 py-3 text-sm font-semibold"
        >
          Talk to the team
        </a>
      </div>
    </div>
  </section>
</MarketingLayout>
