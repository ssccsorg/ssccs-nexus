# EdgeQuake Environment Configuration Template
# Copy this file to .env and fill in your actual values

# =============================================================================
# LLM Provider Configuration (CRITICAL - READ THIS)
# =============================================================================
# EdgeQuake uses explicit environment variables to determine which LLM provider to use.
#
# RECOMMENDATION: Prefer the canonical EDGEQUAKE_* names below. Compatibility
# aliases (`MODEL_PROVIDER`, `CHAT_MODEL`, `EMBEDDING_PROVIDER`,
# `EMBEDDING_MODEL`, `EMBEDDING_DIMENSION`) are also accepted for migration,
# but the canonical EdgeQuake names take precedence.

# -----------------------------------------------------------------------------
# Workspace Default Models (REQUIRED FOR PREDICTABLE CONFIGURATION)
# -----------------------------------------------------------------------------
# These environment variables define the default provider for all workspaces.
# ALWAYS SET THESE to avoid auto-detection behavior:

EDGEQUAKE_DEFAULT_LLM_PROVIDER=openai
EDGEQUAKE_DEFAULT_LLM_MODEL=gpt-5-mini
EDGEQUAKE_DEFAULT_EMBEDDING_PROVIDER=openai
EDGEQUAKE_DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
EDGEQUAKE_DEFAULT_EMBEDDING_DIMENSION=1536

# Compatibility aliases (optional; useful when reusing a LightRAG-style env file)
# MODEL_PROVIDER=openai
# CHAT_MODEL=gpt-5-mini
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSION=1536

# SPEC-040: Vision LLM for PDF-to-Markdown conversion (edgequake-pdf2md)
# Uses a vision-capable model to extract structured Markdown from PDF page images.
# Default: gpt-4.1-nano (~$0.02 per 50-page document)
EDGEQUAKE_VISION_PROVIDER=openai
EDGEQUAKE_VISION_MODEL=gpt-4.1-nano
# Alternative vision models:
# EDGEQUAKE_VISION_MODEL=gpt-4.1-mini          # Higher quality, ~8x cost
# EDGEQUAKE_VISION_MODEL=gpt-4.1               # Highest quality, ~100x cost
# EDGEQUAKE_VISION_PROVIDER=anthropic
# EDGEQUAKE_VISION_MODEL=claude-haiku-4-20250514
# EDGEQUAKE_VISION_PROVIDER=gemini
# EDGEQUAKE_VISION_MODEL=gemini-2.0-flash      # Free tier available
# EDGEQUAKE_VISION_PROVIDER=ollama
# EDGEQUAKE_VISION_MODEL=llava                 # Free, requires local Ollama

# Alternative: Use Ollama for local development
# EDGEQUAKE_DEFAULT_LLM_PROVIDER=ollama
# EDGEQUAKE_DEFAULT_LLM_MODEL=gemma4:latest
# EDGEQUAKE_DEFAULT_EMBEDDING_PROVIDER=ollama
# EDGEQUAKE_DEFAULT_EMBEDDING_MODEL=embeddinggemma:latest
# EDGEQUAKE_DEFAULT_EMBEDDING_DIMENSION=768

# -----------------------------------------------------------------------------
# Option 1: OpenAI (Cloud-hosted, requires API key)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1  # Optional: custom endpoint

# Default OpenAI Models:
#   - Chat/LLM: gpt-5-mini
#   - Embedding: text-embedding-3-small (1536 dimensions)

# -----------------------------------------------------------------------------
# Option 2: Ollama (Local/remote, self-hosted) - RECOMMENDED FOR DEVELOPMENT
# -----------------------------------------------------------------------------
OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=gemma4:latest                  # Chat model (128K context, vision)
# OLLAMA_EMBEDDING_MODEL=embeddinggemma:latest # Embedding model (768 dimensions)

# Default Ollama Models (set in models.toml):
#   - Chat/LLM: gemma4:latest (128K context, vision support)
#   - Embedding: embeddinggemma:latest (768 dimensions)

# -----------------------------------------------------------------------------
# Hybrid Provider Mode: Separate embedding host (closes GitHub issue #140)
# Use a dedicated Ollama node for embeddings while a different provider handles LLM.
# Priority: EDGEQUAKE_EMBEDDING_PROVIDER > OLLAMA_EMBEDDING_HOST > default
# -----------------------------------------------------------------------------
# Separate Ollama host exclusively for embedding generation
# OLLAMA_EMBEDDING_HOST=http://gpu-embedding-server:11434

# Explicitly select an embedding provider (overrides OLLAMA_EMBEDDING_HOST)
# EDGEQUAKE_EMBEDDING_PROVIDER=ollama     # ollama | openai | lmstudio | mock
# EDGEQUAKE_EMBEDDING_MODEL=nomic-embed-text
# EDGEQUAKE_EMBEDDING_DIMENSION=768

# Example — OpenAI for LLM, Ollama on a dedicated GPU box for embeddings:
# EDGEQUAKE_LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OLLAMA_EMBEDDING_HOST=http://gpu-box:11434
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# -----------------------------------------------------------------------------
# Option 3: MiniMax (Cloud-hosted, OpenAI-compatible API)
# -----------------------------------------------------------------------------
# MINIMAX_API_KEY=your-minimax-api-key-here
# MINIMAX_BASE_URL=https://api.minimax.io/v1  # Optional: default is https://api.minimax.io/v1
# For China mainland, use: https://api.minimaxi.com/v1

# Default MiniMax Models (set in models.toml):
#   - Chat/LLM: MiniMax-M2.7 (204K context, latest flagship model)
#   - Fast: MiniMax-M2.7-highspeed (204K context, low-latency)
#   - Legacy: MiniMax-M2.5, MiniMax-M2.5-highspeed

# -----------------------------------------------------------------------------
# Option 5: Mistral AI (Cloud-hosted, La Plateforme) - RECOMMENDED FOR PRODUCTION
# Get your key at: https://console.mistral.ai
# -----------------------------------------------------------------------------
# MISTRAL_API_KEY=your-mistral-api-key-here
# MISTRAL_BASE_URL=https://api.mistral.ai/v1  # Optional: default endpoint

# To make Mistral the default LLM + embedding provider:
# EDGEQUAKE_LLM_PROVIDER=mistral
# EDGEQUAKE_DEFAULT_LLM_MODEL=mistral-small-latest   # cost-effective default

# To use native Mistral embeddings (1024 dimensions):
# EDGEQUAKE_EMBEDDING_PROVIDER=mistral
# MISTRAL_EMBEDDING_MODEL=mistral-embed              # 1024-dimensional vectors

# To use Mistral's vision model for PDF ingestion:
# EDGEQUAKE_VISION_PROVIDER=mistral
# EDGEQUAKE_VISION_MODEL=pixtral-large-latest        # flagship PDF/image model

# Full Mistral stack example (LLM + embedding + vision):
# MISTRAL_API_KEY=your-mistral-api-key-here
# EDGEQUAKE_LLM_PROVIDER=mistral
# EDGEQUAKE_DEFAULT_LLM_MODEL=mistral-small-latest
# EDGEQUAKE_EMBEDDING_PROVIDER=mistral
# MISTRAL_EMBEDDING_MODEL=mistral-embed
# EDGEQUAKE_VISION_PROVIDER=mistral
# EDGEQUAKE_VISION_MODEL=pixtral-large-latest

# Available Mistral models:
#   LLM:      mistral-small-latest, mistral-medium-latest, mistral-large-latest
#   Reasoning: magistral-small-latest, magistral-medium-latest
#   Code:      codestral-latest, devstral-latest
#   Vision:    pixtral-large-latest (recommended for PDF), pixtral-12b-2409
#   Embedding: mistral-embed (1024d), codestral-embed (1024d)

# -----------------------------------------------------------------------------
# Option 4: LM Studio (Local, OpenAI-compatible API)
# -----------------------------------------------------------------------------
# LMSTUDIO_HOST=http://localhost:1234
# LMSTUDIO_MODEL=gemma2-9b-it                # Chat model
# LMSTUDIO_EMBEDDING_MODEL=nomic-embed-text  # Embedding model
# LMSTUDIO_EMBEDDING_DIM=768                 # Embedding dimension

# =============================================================================
# Database Configuration
# =============================================================================
# PostgreSQL is required for server mode.
# Format: postgresql://username:password@host:port/database
# WHY ?options=-c%20search_path%3Dpublic: Forces search_path=public at the
# connection level. Without this, sqlx-cli uses the edgequake schema for
# _sqlx_migrations tracking (because "$user"=edgequake schema exists after
# migration 001), causing duplicate-key errors on every restart.
# DATABASE_URL=postgresql://edgequake:edgequake_secret@localhost:5432/edgequake?options=-c%20search_path%3Dpublic

# =============================================================================
# Server Configuration
# =============================================================================
HOST=0.0.0.0
PORT=8080

# =============================================================================
# PDF Extraction Configuration
# =============================================================================
# pdfium is embedded automatically via edgequake-pdf2md/pdfium-auto.
# No PDFIUM_DYNAMIC_LIB_PATH is required for normal installs.

# =============================================================================
# Worker Configuration
# =============================================================================
# Number of background workers for document processing
WORKER_THREADS=4

# =============================================================================
# Logging Configuration
# =============================================================================
# Logging Level
# Options: trace, debug, info, warn, error
RUST_LOG=edgequake=debug,tower_http=debug,axum=debug

# =============================================================================
# Frontend Configuration
# =============================================================================
# Disable the demo login button in production deployments (closes GitHub issue #139).
# When set to "true" the "Continue without login (Demo)" button is hidden on the
# login page.  Leave unset or set to "false" for development / demo environments.
# NEXT_PUBLIC_DISABLE_DEMO_LOGIN=true
