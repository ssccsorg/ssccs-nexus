---
const navLinks = [
  { label: "Docs", href: "/docs/" },
  { label: "Demo", href: "/demo/" },
  { label: "Ecosystem", href: "/ecosystem/" },
  { label: "Enterprise", href: "/enterprise/" },
];

const pathname = Astro.url.pathname;
const isActivePath = (href: string) => {
  if (href === "/docs/") {
    return pathname.startsWith("/docs/");
  }

  return pathname === href;
};
---

<header
  class="sticky top-0 z-50 w-full mkt-border-subtle border-b mkt-bg-header backdrop-blur-lg"
  data-pagefind-ignore
>
  <div
    class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8"
  >
    <!-- Logo -->
    <a
      href="/"
      class="flex items-center gap-2 mkt-text hover:opacity-90 transition-opacity"
    >
      <svg
        class="h-7 w-7 text-accent-500"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
      </svg>
      <span class="text-lg font-bold tracking-tight">EdgeQuake</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="mkt-nav-link px-3 py-2 text-sm font-medium"
            aria-current={isActivePath(link.href) ? "page" : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <!-- Actions -->
    <div class="flex items-center gap-2">
      <!-- Theme toggle -->
      <button
        type="button"
        id="theme-toggle"
        class="inline-flex items-center justify-center rounded-md p-2 mkt-text-muted hover:mkt-text mkt-hover-bg transition-colors"
        aria-label="Toggle color theme"
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg
          class="h-5 w-5 theme-icon-sun"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="12" cy="12" r="5"></circle>
          <line x1="12" y1="1" x2="12" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="23"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="1" y1="12" x2="3" y2="12"></line>
          <line x1="21" y1="12" x2="23" y2="12"></line>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg
          class="h-5 w-5 theme-icon-moon"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>

      <!-- GitHub -->
      <a
        href="https://github.com/raphaelmansuy/edgequake"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden sm:flex items-center justify-center rounded-md p-2 mkt-text-muted hover:mkt-text mkt-hover-bg transition-colors"
        aria-label="GitHub"
      >
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
          <path
            d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
          ></path>
        </svg>
      </a>

      <!-- Get Started CTA -->
      <a
        href="/docs/getting-started/"
        class="hidden sm:inline-flex items-center rounded-lg bg-accent-600 px-4 py-2 text-sm font-semibold text-white hover:bg-accent-500 transition-colors"
      >
        Get Started
      </a>

      <!-- Mobile menu button -->
      <button
        type="button"
        class="md:hidden inline-flex items-center justify-center rounded-md p-2 mkt-text-muted hover:mkt-text mkt-hover-bg"
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label="Open menu"
        id="mobile-menu-btn"
      >
        <svg
          class="h-6 w-6"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <nav
    id="mobile-menu"
    class="hidden md:hidden mkt-border-subtle border-t mkt-bg-header backdrop-blur-lg"
    aria-label="Mobile navigation"
    aria-hidden="true"
  >
    <div class="space-y-1 px-4 py-3">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="mkt-nav-link block px-3 py-2 text-base font-medium"
            aria-current={isActivePath(link.href) ? "page" : undefined}
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="/docs/getting-started/"
        class="block rounded-md bg-accent-600 px-3 py-2 text-base font-semibold text-white hover:bg-accent-500 transition-colors"
      >
        Get Started →
      </a>
      <a
        href="https://github.com/raphaelmansuy/edgequake"
        target="_blank"
        rel="noopener noreferrer"
        class="mkt-nav-link block px-3 py-2 text-base font-medium"
      >
        GitHub
      </a>
    </div>
  </nav>
</header>

<style>
  /* Theme toggle icon visibility */
  :root[data-theme="light"] .theme-icon-moon {
    display: block;
  }
  :root[data-theme="light"] .theme-icon-sun {
    display: none;
  }
  :root:not([data-theme="light"]) .theme-icon-moon {
    display: none;
  }
  :root:not([data-theme="light"]) .theme-icon-sun {
    display: block;
  }
</style>

<script>
  const syncThemeMeta = (theme: string) => {
    document.querySelectorAll('meta[name="theme-color"]').forEach((meta) => {
      if (!meta.hasAttribute("media")) {
        meta.setAttribute("content", theme === "light" ? "#ffffff" : "#09090b");
      }
    });
  };

  const updateThemeButtonLabel = (theme: string) => {
    const themeBtn = document.getElementById("theme-toggle");
    themeBtn?.setAttribute(
      "aria-label",
      theme === "light" ? "Switch to dark mode" : "Switch to light mode",
    );
  };

  const setupHeader = () => {
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    const themeBtn = document.getElementById("theme-toggle");

    if (btn && menu && !btn.dataset.bound) {
      const menuLinks = Array.from(menu.querySelectorAll("a"));

      const setMenuState = (expanded: boolean) => {
        menu.classList.toggle("hidden", !expanded);
        btn.setAttribute("aria-expanded", String(expanded));
        menu.setAttribute("aria-hidden", String(!expanded));
        btn.setAttribute("aria-label", expanded ? "Close menu" : "Open menu");
        document.body.style.overflow = expanded ? "hidden" : "";

        if (expanded) {
          menuLinks[0]?.focus();
        }
      };

      btn.addEventListener("click", () => {
        const expanded = btn.getAttribute("aria-expanded") === "true";
        setMenuState(!expanded);
      });

      menuLinks.forEach((link) => {
        link.addEventListener("click", () => setMenuState(false));
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          setMenuState(false);
          btn.focus();
        }

        if (
          event.key === "Tab" &&
          btn.getAttribute("aria-expanded") === "true" &&
          menuLinks.length > 0
        ) {
          const first = menuLinks[0];
          const last = menuLinks[menuLinks.length - 1];
          const active = document.activeElement;

          if (event.shiftKey && active === first) {
            event.preventDefault();
            last.focus();
          } else if (!event.shiftKey && active === last) {
            event.preventDefault();
            first.focus();
          }
        }
      });

      document.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Node)) {
          return;
        }

        const expanded = btn.getAttribute("aria-expanded") === "true";
        if (expanded && !menu.contains(target) && !btn.contains(target)) {
          setMenuState(false);
        }
      });

      window.addEventListener("resize", () => {
        if (window.innerWidth >= 768) {
          setMenuState(false);
        }
      });

      btn.dataset.bound = "true";
      setMenuState(false);
    }

    if (themeBtn && !themeBtn.dataset.bound) {
      themeBtn.addEventListener("click", () => {
        const current = document.documentElement.getAttribute("data-theme");
        const next = current === "light" ? "dark" : "light";
        document.documentElement.setAttribute("data-theme", next);
        localStorage.setItem("starlight-theme", next);
        syncThemeMeta(next);
        updateThemeButtonLabel(next);
      });

      themeBtn.dataset.bound = "true";
    }

    const activeTheme =
      document.documentElement.getAttribute("data-theme") || "dark";
    syncThemeMeta(activeTheme);
    updateThemeButtonLabel(activeTheme);
  };

  setupHeader();
</script>
