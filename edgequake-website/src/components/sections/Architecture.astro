---
/**
 * Architecture section — System pipeline diagram.
 * Ported from _archive/architecture.tsx (inline SVG)
 */
---

<section class="mkt-section-alt py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto">
      <h2 class="text-3xl font-bold tracking-tight mkt-text sm:text-4xl">
        From Source Files to Grounded Answers
      </h2>
      <p class="mt-4 text-lg mkt-text-muted">
        Documents move through ingestion, extraction, graph storage, retrieval,
        and API delivery in one coherent pipeline.
      </p>
    </div>

    <div class="mt-12 flex justify-center">
      <div class="mkt-card w-full max-w-4xl rounded-xl p-4 sm:p-8">

        <!-- Mobile pipeline: vertical steps (visible on xs/sm only) -->
        <div class="sm:hidden">
          <ol class="flex flex-col items-center gap-1">
            {[
              "Documents",
              "Ingestion Pipeline",
              "PostgreSQL Storage",
              "Query Engine",
              "REST API",
            ].map((stage, i) => (
              <li class="flex w-full flex-col items-center">
                <div class="w-full rounded-lg border border-blue-500/70 bg-[#1e3a5f] px-4 py-3 text-center">
                  <span class="text-sm font-semibold text-blue-300">{stage}</span>
                </div>
                {i < 4 && (
                  <svg
                    width="16"
                    height="20"
                    viewBox="0 0 16 20"
                    aria-hidden="true"
                  >
                    <line
                      x1="8"
                      y1="0"
                      x2="8"
                      y2="14"
                      stroke="#3b82f6"
                      stroke-width="1.5"
                    />
                    <polygon points="2,12 8,20 14,12" fill="#3b82f6" />
                  </svg>
                )}
              </li>
            ))}
          </ol>
          <div class="mt-4 flex justify-center gap-4">
            <span class="rounded-md border border-dashed border-zinc-500/60 px-3 py-1.5 text-xs text-zinc-400">
              LLM Provider
            </span>
            <span class="rounded-md border border-dashed border-zinc-500/60 px-3 py-1.5 text-xs text-zinc-400">
              Clients
            </span>
          </div>
        </div>

        <!-- Desktop/tablet pipeline: horizontal SVG (hidden on xs) -->
        <div class="hidden sm:block overflow-x-auto">
        <svg
          viewBox="0 0 800 340"
          class="w-full min-w-[640px]"
          xmlns="http://www.w3.org/2000/svg"
        >
          <!-- Boxes -->
          <g
            font-family="Inter, sans-serif"
            font-size="13"
            text-anchor="middle"
          >
            <!-- Documents -->
            <rect
              x="20"
              y="130"
              width="110"
              height="60"
              rx="8"
              fill="#1e3a5f"
              stroke="#3b82f6"
              stroke-width="1.5"></rect>
            <text x="75" y="165" fill="#93c5fd" font-weight="600"
              >Documents</text
            >

            <!-- Ingestion Pipeline -->
            <rect
              x="170"
              y="130"
              width="140"
              height="60"
              rx="8"
              fill="#1e3a5f"
              stroke="#3b82f6"
              stroke-width="1.5"></rect>
            <text x="240" y="158" fill="#93c5fd" font-weight="600"
              >Ingestion</text
            >
            <text x="240" y="175" fill="#93c5fd" font-weight="600"
              >Pipeline</text
            >

            <!-- PostgreSQL Storage -->
            <rect
              x="350"
              y="130"
              width="140"
              height="60"
              rx="8"
              fill="#1e3a5f"
              stroke="#3b82f6"
              stroke-width="1.5"></rect>
            <text x="420" y="158" fill="#93c5fd" font-weight="600"
              >PostgreSQL</text
            >
            <text x="420" y="175" fill="#93c5fd" font-weight="600">Storage</text
            >

            <!-- Query Engine -->
            <rect
              x="530"
              y="130"
              width="120"
              height="60"
              rx="8"
              fill="#1e3a5f"
              stroke="#3b82f6"
              stroke-width="1.5"></rect>
            <text x="590" y="165" fill="#93c5fd" font-weight="600"
              >Query Engine</text
            >

            <!-- REST API -->
            <rect
              x="690"
              y="130"
              width="90"
              height="60"
              rx="8"
              fill="#1e3a5f"
              stroke="#3b82f6"
              stroke-width="1.5"></rect>
            <text x="735" y="165" fill="#93c5fd" font-weight="600"
              >REST API</text
            >

            <!-- LLM Provider (dashed) -->
            <rect
              x="300"
              y="260"
              width="140"
              height="50"
              rx="8"
              fill="none"
              stroke="#71717a"
              stroke-width="1.5"
              stroke-dasharray="6 3"></rect>
            <text x="370" y="290" fill="#a1a1aa" font-weight="500"
              >LLM Provider</text
            >

            <!-- Clients -->
            <rect
              x="660"
              y="260"
              width="120"
              height="50"
              rx="8"
              fill="none"
              stroke="#71717a"
              stroke-width="1.5"
              stroke-dasharray="6 3"></rect>
            <text x="720" y="290" fill="#a1a1aa" font-weight="500">Clients</text
            >
          </g>

          <!-- Arrows -->
          <g
            stroke="#3b82f6"
            stroke-width="1.5"
            fill="none"
            marker-end="url(#arrow)"
          >
            <line x1="130" y1="160" x2="170" y2="160"></line>
            <line x1="310" y1="160" x2="350" y2="160"></line>
            <line x1="490" y1="160" x2="530" y2="160"></line>
            <line x1="650" y1="160" x2="690" y2="160"></line>
            <!-- LLM connections -->
            <line
              x1="370"
              y1="260"
              x2="240"
              y2="190"
              stroke="#71717a"
              stroke-dasharray="4 3"></line>
            <line
              x1="370"
              y1="260"
              x2="590"
              y2="190"
              stroke="#71717a"
              stroke-dasharray="4 3"></line>
            <!-- Client connection -->
            <line
              x1="735"
              y1="260"
              x2="735"
              y2="190"
              stroke="#71717a"
              stroke-dasharray="4 3"></line>
          </g>

          <!-- Arrow marker -->
          <defs>
            <marker
              id="arrow"
              markerWidth="10"
              markerHeight="7"
              refX="10"
              refY="3.5"
              orient="auto"
            >
              <polygon points="0 0, 10 3.5, 0 7" fill="#3b82f6"></polygon>
            </marker>
          </defs>
        </svg>
        </div><!-- end hidden sm:block -->

        <p class="mt-6 text-sm leading-relaxed mkt-text-muted">
          The key idea is simple: ingest source material once, preserve
          structure and lineage, then serve multiple retrieval strategies from a
          storage layer designed for production rather than prototypes.
        </p>
      </div>
    </div>
  </div>
</section>
